# Copy to key.properties (same folder) and fill in real values.
# key.properties is gitignored — never commit secrets or the keystore file.
#
# Create an upload keystore (once):
#   keytool -genkey -v -keystore upload-keystore.jks -keyalg RSA \
#     -keysize 2048 -validity 10000 -alias upload
#
# Put upload-keystore.jks in this android/ directory (or use an absolute path).

storePassword=your-store-password
keyPassword=your-key-password
keyAlias=upload
storeFile=upload-keystore.jks
